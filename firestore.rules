rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // UserProfile Entity Validation
    function isValidUserProfile(data) {
      return data.uid is string &&
             data.uid.size() <= 128 &&
             data.name is string &&
             data.name.size() <= 100 &&
             data.phone is string &&
             data.phone.size() <= 20 &&
             data.role is string &&
             (data.role == "customer" || data.role == "admin" || data.role == "delivery" || data.role == "seller") &&
             data.walletBalance is number &&
             data.walletBalance >= 0 &&
             data.loyaltyPoints is number &&
             data.loyaltyPoints >= 0 &&
             data.referralCode is string &&
             data.referralCode.size() <= 30 &&
             data.customerId is string &&
             data.customerId.size() <= 30 &&
             data.status is string &&
             (data.status == "Active" || data.status == "Blocked") &&
             data.orderCount is number &&
             data.orderCount >= 0 &&
             (!('email' in data) || (data.email is string && data.email.size() <= 100)) &&
             (!('referredBy' in data) || (data.referredBy is string && data.referredBy.size() <= 30)) &&
             (!('photoUrl' in data) || (data.photoUrl is string && data.photoUrl.size() <= 500)) &&
             (!('recentlyViewed' in data) || (data.recentlyViewed is list)) &&
             (!('savedProducts' in data) || (data.savedProducts is list));
    }

    // Address Entity Validation
    function isValidAddress(data) {
      return data.id is string &&
             data.id.size() <= 128 &&
             data.type is string &&
             (data.type == "Home" || data.type == "Work" || data.type == "Other") &&
             data.houseFlat is string &&
             data.houseFlat.size() <= 100 &&
             (!('buildingName' in data) || (data.buildingName is string && data.buildingName.size() <= 100)) &&
             data.streetArea is string &&
             data.streetArea.size() <= 200 &&
             (!('landmark' in data) || (data.landmark is string && data.landmark.size() <= 150)) &&
             data.city is string &&
             data.city.size() <= 100 &&
             data.state is string &&
             data.state.size() <= 100 &&
             data.pinCode is string &&
             data.pinCode.size() <= 10 &&
             data.isDefault is bool &&
             (!('latitude' in data) || (data.latitude is number)) &&
             (!('longitude' in data) || (data.longitude is number));
    }

    // 3. Collection Rules

    // Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Strict rule: list is blocked to avoid blanket scraping
      allow list: if isAdmin();

      allow create: if (
        isOwner(userId) &&
        isValidUserProfile(incoming()) &&
        incoming().uid == userId &&
        incoming().createdAt == request.time &&
        incoming().role == "customer" && // customer role only for registration
        incoming().walletBalance == 0 && // starts at 0 unless coupon applied
        incoming().loyaltyPoints == 0 && // starts at 0
        incoming().orderCount == 0 && // starts at 0
        incoming().status == "Active" // starts as Active
      );

      allow update: if (
        (isOwner(userId) &&
         isValidUserProfile(incoming()) &&
         incoming().uid == userId &&
         incoming().createdAt == existing().createdAt && // immutable
         incoming().customerId == existing().customerId && // immutable
         (
           // Action: Customer edits their own basic profile fields
           incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'photoUrl', 'recentlyViewed', 'savedProducts', 'lastLogin']) ||
           
           // Action: Wallet/loyalty updates (only allowed during valid transactions, but here we can whitelist fields for the user)
           incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'phone', 'photoUrl', 'recentlyViewed', 'savedProducts', 'lastLogin', 'walletBalance', 'loyaltyPoints', 'orderCount'])
         )
        ) || isAdmin()
      );

      allow delete: if isAdmin();

      // Subcollection: Addresses
      match /addresses/{addressId} {
        allow read: if isOwner(userId) || isAdmin();
        
        allow create, update: if (
          isOwner(userId) &&
          isValidId(addressId) &&
          isValidAddress(incoming()) &&
          incoming().id == addressId
        );

        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    // Admins helper lookup collection
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable directly from Firebase console
    }
  }
}
